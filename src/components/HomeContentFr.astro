                aria-labelledby="faq-q-1"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      We quote based on your scope. Schedule a call, we'll give
                      you numbers upfront. Transparency first.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-2"
                  id="faq-q-2"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Quel delai pour les premiers resultats ?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-2"
                role="region"
                aria-labelledby="faq-q-2"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      You see automations working in 2-3 weeks. Full deployment
                      depends on your systems. Most teams are productive within
                      6-8 weeks.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-3"
                  id="faq-q-3"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Dois-je changer mon equipe ou mes processus ?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-3"
                role="region"
                aria-labelledby="faq-q-3"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      No. We adapt to how you work now. If your process is
                      broken, we'll tell you. But we don't force reorganization.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-4"
                  id="faq-q-4"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Comment mesurez-vous le succes ?</span
