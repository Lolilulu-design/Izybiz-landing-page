---
import Layout from "../../layouts/Layout.astro";

const lang = "es";
---

<Layout
  lang={lang}
  title="Izybiz | Sobre mí"
  description="Página sobre mí"
>
  <main class="page-shell">
    <section class="section-one" aria-label="Page content">
      <div class="hero-izybiz">
        <div class="hero-izybiz__text">
          <h1 class="hero-izybiz__title">
            <span class="hero-izybiz__title-line hero-izybiz__title-line--visible">Sobre mí</span>
          </h1>
          <p class="hero-izybiz__subtitle hero-izybiz__subtitle--visible">
            <span>Contenido próximamente.</span>
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
